{
  "name": "time-report",
  "steps": [
    {
      "call": "get-time.sensor",
      "format": "%Y-%m-%d %H:%M:%S",
      "as": "current_time"
    },
    {
      "call": "get-time.sensor",
      "format": "%A, %B %d, %Y",
      "as": "formatted_date"
    },
    {
      "call": "print-time.action",
      "time": "${current_time}",
      "message": "Current timestamp"
    },
    {
      "call": "print-time.action",
      "time": "${formatted_date}",
      "message": "Today's date"
    },
    {
      "call": "echo.action",
      "data": "Time report completed successfully!"
    }
  ]
}
