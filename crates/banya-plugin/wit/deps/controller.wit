package banya:controller@0.1.0;
 
interface controller {
  type bytes = list<u8>;
  execute: func(name: string, capability: string, data: bytes) -> result<option<bytes>, string>;
  get: func(name: string) -> option<bytes>;
  put: func(name: string, data: bytes) -> option<bytes>;
  remove: func(name: string) -> option<bytes>;
}

world app {
  import controller;
}